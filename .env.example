# Recall.ai (shared server-side credential)
RECALL_API_KEY=your-recall-api-key
RECALL_REGION=us-west-2

# Public URL — how Recall's bot reaches this server
# For local dev: use ngrok (ngrok http 3000)
# For Railway: leave unset, auto-detected from RAILWAY_PUBLIC_DOMAIN
PUBLIC_URL=https://your-subdomain.ngrok-free.app

PORT=3000

# Runway API keys are entered per-user in the browser UI (not needed here)
